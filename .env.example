# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GitHub Integration ────────────────────────────────────────────────────────
# Personal access token with repo, issues, webhooks scopes
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=Garrettc123
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Linear Integration ────────────────────────────────────────────────────────
# Linear API key from https://linear.app/settings/api
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret_here

# ─── Notion Integration ────────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── Perplexity AI ─────────────────────────────────────────────────────────────
# API key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=llama-3.1-sonar-small-128k-online

# ─── Optional: Databases ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost/db
MONGODB_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379

# ─── Optional: Kafka / gRPC ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
GRPC_HOST=localhost
GRPC_PORT=50051

# ─── Agent System ─────────────────────────────────────────────────────────────
AGENT_MODE=development
AGENT_AUTO_EXECUTE=false
