# Tree of Life System - Environment Configuration
# Copy this file to .env and fill in your values
# Railway will use these variables from your project's Variables tab

# ============================================
# SERVER CONFIGURATION
# ============================================
# Railway automatically sets PORT - do not override in Railway dashboard
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ============================================
# GITHUB INTEGRATION
# ============================================
# Personal Access Token with repo, read:org, and webhook permissions
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_OWNER=Garrettc123
GITHUB_REPO=tree-of-life-system

# ============================================
# LINEAR INTEGRATION
# ============================================
# API key from: https://linear.app/settings/api
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret_here

# ============================================
# NOTION INTEGRATION
# ============================================
# Integration token from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_WEBHOOK_SECRET=your_notion_webhook_secret_here

# ============================================
# PERPLEXITY AI INTEGRATION
# ============================================
# API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro

# ============================================
# OPENAI INTEGRATION (optional)
# ============================================
# API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ============================================
# DATABASE (optional - add Railway PostgreSQL plugin)
# ============================================
# Railway auto-fills DATABASE_URL when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_jwt_secret_at_least_32_chars_here
ENCRYPTION_KEY=your_encryption_key_at_least_32_chars_here

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AUTO_MARKETING=true
ENABLE_SELF_HEALING=true
ENABLE_PREDICTIVE_INTEL=true

